PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE

CALL_PROVIDER=exotel
PUBLIC_BACKEND_URL=https://YOUR-BACKEND.onrender.com
STALE_CALL_TIMEOUT_MS=300000

EXOTEL_ACCOUNT_SID=YOUR_ACCOUNT_SID
EXOTEL_API_KEY=YOUR_API_KEY
EXOTEL_API_TOKEN=YOUR_API_TOKEN
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=YOUR_EXOPHONE
EXOTEL_FLOW_ID=YOUR_FLOW_ID
EXOTEL_WEBHOOK_SECRET=GENERATE_A_PRIVATE_WEBHOOK_SECRET
EXOTEL_REQUEST_TIMEOUT_MS=30000

# Primary administrator
ADMIN_EMAIL=first-admin@example.com
ADMIN_PASSWORD_HASH=PASTE_FIRST_ADMIN_BCRYPT_HASH

# Second administrator with a different password
ADMIN_EMAIL_2=second-admin@example.com
ADMIN_PASSWORD_HASH_2=PASTE_SECOND_ADMIN_BCRYPT_HASH

# Add more administrators with matching numbered pairs when needed:
# ADMIN_EMAIL_3=third-admin@example.com
# ADMIN_PASSWORD_HASH_3=PASTE_THIRD_ADMIN_BCRYPT_HASH

JWT_SECRET=GENERATE_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h
