PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE

CALL_PROVIDER=exotel
PUBLIC_BACKEND_URL=https://YOUR-BACKEND.onrender.com
STALE_CALL_TIMEOUT_MS=300000

EXOTEL_ACCOUNT_SID=YOUR_ACCOUNT_SID
EXOTEL_API_KEY=YOUR_API_KEY
EXOTEL_API_TOKEN=YOUR_API_TOKEN
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=YOUR_EXOPHONE
EXOTEL_FLOW_ID=YOUR_FLOW_ID
EXOTEL_WEBHOOK_SECRET=GENERATE_A_PRIVATE_WEBHOOK_SECRET
EXOTEL_REQUEST_TIMEOUT_MS=30000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=PASTE_BCRYPT_HASH_HERE
JWT_SECRET=GENERATE_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h
