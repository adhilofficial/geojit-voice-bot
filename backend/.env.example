PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE_NAME
CALL_PROVIDER=exotel
PUBLIC_BACKEND_URL=https://YOUR-RENDER-SERVICE.onrender.com
EXOTEL_ACCOUNT_SID=YOUR_ACCOUNT_SID
EXOTEL_API_KEY=YOUR_API_KEY
EXOTEL_API_TOKEN=YOUR_API_TOKEN
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=YOUR_EXOPHONE
EXOTEL_FLOW_ID=YOUR_FLOW_ID
EXOTEL_WEBHOOK_SECRET=CREATE_A_RANDOM_SECRET
EXOTEL_REQUEST_TIMEOUT_MS=20000
STALE_CALL_TIMEOUT_MS=300000
