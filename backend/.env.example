PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=YOUR_MONGODB_ATLAS_CONNECTION_STRING

CALL_PROVIDER=exotel
EXOTEL_ACCOUNT_SID=saivo1
EXOTEL_API_KEY=YOUR_EXOTEL_API_KEY
EXOTEL_API_TOKEN=YOUR_EXOTEL_API_TOKEN
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=YOUR_EXOPHONE
EXOTEL_FLOW_ID=YOUR_FLOW_ID
PUBLIC_BACKEND_URL=https://your-backend-domain.example.com

# Optional but recommended. Use the same random value in Render.
EXOTEL_WEBHOOK_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET

# Optional; allowed range is 5000 to 60000 milliseconds.
EXOTEL_REQUEST_TIMEOUT_MS=20000

# Active calls older than this are automatically marked failed.
STALE_CALL_TIMEOUT_MS=300000
